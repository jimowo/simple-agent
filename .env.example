# simple-agent Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# AI Provider Configuration
# ============================================================================

# Default AI provider to use
# Options: anthropic, openai, gemini, groq, local
DEFAULT_PROVIDER=anthropic

# Runtime provider override (optional)
# PROVIDER=anthropic

# Optional: Custom model ID override
# MODEL_ID=

# ============================================================================
# API Keys
# ============================================================================

# Anthropic (Claude) API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT-4o, o1, o3-mini, etc.)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
# Get yours at: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (for fast inference with Llama models)
# Get yours at: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# Provider Base URLs (Optional)
# ============================================================================

# Custom Anthropic base URL (for proxy or custom endpoints)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================================================
# Agent Settings
# ============================================================================

# Token threshold for context compression
# TOKEN_THRESHOLD=100000

# Maximum tokens for AI responses
# MAX_TOKENS=8000

# Poll interval for teammate messages (seconds)
# POLL_INTERVAL=5

# Idle timeout before teammate shutdown (seconds)
# IDLE_TIMEOUT=60

# ============================================================================
# Bash Settings
# ============================================================================

# Default timeout for bash commands (seconds)
# BASH_TIMEOUT=120

# ============================================================================
# Directory Paths (Optional - defaults shown)
# ============================================================================

# Working directory (default: current directory)
# workdir=.

# Team configuration directory
# team_dir=.team

# Inbox directory for messages
# inbox_dir=.team/inbox

# Tasks directory
# tasks_dir=.tasks

# Skills directory for custom prompts
# skills_dir=skills

# Transcript directory for conversation logs
# transcript_dir=.transcripts

# Logs directory
# logs_dir=.logs
